{
  "name": "@weaverse/animate-loading",
  "type": "module",
  "version": "2.2.0",
  "description": "Lightweight TypeScript loading bar library like Shopify, Github, JSFiddle... that works!",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "default": "./dist/index.js"
      },
      "require": {
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Weaverse/animate-loading-bar.git"
  },
  "keywords": [
    "loading-bar",
    "progress-bar",
    "loading-indicator",
    "vanilla-js",
    "typescript",
    "css",
    "animation",
    "ui",
    "frontend",
    "web-components"
  ],
  "author": "Leo @ https://leohuynh.dev",
  "license": "ISC",
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "bugs": {
    "url": "https://github.com/Weaverse/animate-loading-bar/issues"
  },
  "homepage": "https://github.com/Weaverse/animate-loading-bar#readme"
}
